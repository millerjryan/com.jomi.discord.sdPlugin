{
  "Author": "Josh",
  "Name": "Discord Client Controls",
  "Description": "Control the local Discord client from OpenDeck with native Rust actions.",
  "Category": "Discord",
  "CategoryIcon": "imgs/category-icon",
  "Icon": "imgs/plugin-icon",
  "CodePath": "bin/discord-client-controls",
  "CodePathWin": "bin/discord-client-controls.exe",
  "CodePathLinux": "bin/discord-client-controls",
  "UUID": "com.jomi.discord",
  "Version": "0.1.0.0",
  "SDKVersion": 2,
  "Software": {
    "MinimumVersion": "6.4"
  },
  "OS": [
    {
      "Platform": "windows",
      "MinimumVersion": "10"
    },
    {
      "Platform": "linux",
      "MinimumVersion": "0"
    }
  ],
  "Actions": [
    {
      "Name": "Voice Channel",
      "UUID": "com.jomi.discord.voice-channel",
      "Icon": "imgs/voice-action",
      "Tooltip": "Join a configured Discord voice channel in the local client.",
      "Controllers": [
        "Keypad"
      ],
      "PropertyInspectorPath": "ui/voice-channel.html",
      "States": [
        {
          "Image": "imgs/voice-key",
          "Title": "Voice\nChannel",
          "TitleAlignment": "bottom",
          "ShowTitle": true
        }
      ]
    },
    {
      "Name": "Screenshare",
      "UUID": "com.jomi.discord.screenshare",
      "Icon": "imgs/voice-action",
      "Tooltip": "Toggle Discord screensharing in the local client.",
      "Controllers": [
        "Keypad"
      ],
      "PropertyInspectorPath": "ui/screenshare.html",
      "States": [
        {
          "Image": "imgs/voice-key",
          "Title": "Not\nSharing",
          "TitleAlignment": "bottom",
          "ShowTitle": true
        },
        {
          "Image": "imgs/voice-key",
          "Title": "Sharing",
          "TitleAlignment": "bottom",
          "ShowTitle": true
        }
      ]
    },
    {
      "Name": "Soundboard",
      "UUID": "com.jomi.discord.soundboard",
      "Icon": "imgs/voice-action",
      "Tooltip": "Play a configured Discord soundboard sound in the local client.",
      "Controllers": [
        "Keypad"
      ],
      "PropertyInspectorPath": "ui/soundboard.html",
      "States": [
        {
          "Image": "imgs/voice-key",
          "Title": "Sound\nBoard",
          "TitleAlignment": "bottom",
          "ShowTitle": true
        }
      ]
    }
  ]
}
